<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= title %></title>
    <style>
        :root {
            --bg: #f7f7f2;
            --panel: #ffffff;
            --ink: #14213d;
            --muted: #52606d;
            --accent: #0f766e;
            --accent-dark: #115e59;
            --danger: #b91c1c;
            --border: #d9e2ec;
        }
        * { box-sizing: border-box; }
        body {
            margin: 0;
            font-family: "Trebuchet MS", Verdana, sans-serif;
            background:
                linear-gradient(180deg, rgba(15, 118, 110, 0.14), transparent 220px),
                var(--bg);
            color: var(--ink);
        }
        main {
            max-width: 1150px;
            margin: 0 auto;
            padding: 40px 20px 60px;
        }
        header {
            display: flex;
            justify-content: space-between;
            gap: 16px;
            align-items: end;
            margin-bottom: 24px;
            flex-wrap: wrap;
        }
        h1, h2 { margin: 0; }
        a { color: var(--accent); text-decoration: none; font-weight: 700; }
        .notice, .error {
            margin-bottom: 16px;
            padding: 14px 16px;
            border-radius: 14px;
        }
        .notice {
            background: #dcfce7;
            color: #166534;
        }
        .error {
            background: #fef2f2;
            color: #991b1b;
        }
        .layout {
            display: grid;
            grid-template-columns: 320px 1fr;
            gap: 20px;
        }
        .panel {
            background: var(--panel);
            border-radius: 18px;
            border: 1px solid var(--border);
            box-shadow: 0 18px 50px rgba(20, 33, 61, 0.08);
            padding: 22px;
        }
        .form-grid {
            display: grid;
            gap: 12px;
            margin-top: 16px;
        }
        label {
            display: grid;
            gap: 6px;
            font-weight: 700;
        }
        input {
            width: 100%;
            padding: 11px 12px;
            border: 1px solid var(--border);
            border-radius: 12px;
            font: inherit;
        }
        table {
            width: 100%;
            border-collapse: collapse;
            background: var(--panel);
            border-radius: 18px;
            overflow: hidden;
        }
        th, td {
            text-align: left;
            padding: 16px;
            border-bottom: 1px solid var(--border);
            vertical-align: top;
        }
        th {
            background: #e6fffb;
            font-size: 0.9rem;
            text-transform: uppercase;
            letter-spacing: 0.05em;
        }
        tbody tr:hover { background: #f0fdfa; }
        .empty {
            padding: 32px;
            text-align: center;
            color: var(--muted);
            background: var(--panel);
            border-radius: 18px;
            border: 1px solid var(--border);
        }
        .pill {
            display: inline-block;
            padding: 6px 10px;
            border-radius: 999px;
            background: #ccfbf1;
            color: #115e59;
            font-size: 0.9rem;
            font-weight: 700;
        }
        .actions {
            display: flex;
            flex-wrap: wrap;
            gap: 8px;
            margin-top: 10px;
        }
        .row-form {
            display: grid;
            gap: 10px;
        }
        .row-grid {
            display: grid;
            grid-template-columns: repeat(2, minmax(140px, 1fr));
            gap: 10px;
        }
        button {
            border: 0;
            border-radius: 12px;
            padding: 11px 14px;
            font: inherit;
            font-weight: 700;
            cursor: pointer;
        }
        .primary {
            background: var(--accent);
            color: white;
        }
        .secondary {
            background: #dbeafe;
            color: #1d4ed8;
        }
        .danger {
            background: #fee2e2;
            color: var(--danger);
        }
        .muted {
            color: var(--muted);
        }
        @media (max-width: 900px) {
            .layout { grid-template-columns: 1fr; }
            .row-grid { grid-template-columns: 1fr; }
        }
    </style>
</head>
<body>
    <main>
        <header>
            <div>
                <a href="/">Back to dashboard</a>
                <h1>Clients</h1>
            </div>
            <p>Rendered from the existing client service and department join view.</p>
        </header>

        <% if (message) { %>
            <div class="<%= messageType === 'error' ? 'error' : 'notice' %>"><%= message %></div>
        <% } %>

        <% if (error) { %>
            <div class="error">Unable to load clients: <%= error %></div>
        <% } %>

        <section class="layout">
            <aside class="panel">
                <h2>Create client</h2>
                <p class="muted">Add a new client directly from the views layer.</p>
                <form class="form-grid" method="post" action="/views/clients">
                    <label>
                        Name
                        <input type="text" name="name" placeholder="Client name" required />
                    </label>
                    <label>
                        Email
                        <input type="email" name="email" placeholder="client@example.com" required />
                    </label>
                    <button class="primary" type="submit">Create client</button>
                </form>
            </aside>

            <section>
                <% if (!clients.length) { %>
                    <div class="empty">No clients are available right now.</div>
                <% } else { %>
                    <table>
                        <thead>
                            <tr>
                                <th>ID</th>
                                <th>Client</th>
                                <th>Department</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% clients.forEach((client) => { %>
                                <tr>
                                    <td><%= client.id %></td>
                                    <td>
                                        <strong><%= client.name %></strong><br />
                                        <span class="muted"><%= client.email || "N/A" %></span>
                                    </td>
                                    <td>
                                        <% if (client.department) { %>
                                            <span class="pill"><%= client.department.name %></span>
                                        <% } else { %>
                                            <span class="muted">Unassigned</span>
                                        <% } %>
                                    </td>
                                    <td>
                                        <form class="row-form" method="post" action="/views/clients/<%= client.id %>/update">
                                            <div class="row-grid">
                                                <input type="text" name="name" value="<%= client.name %>" required />
                                                <input type="email" name="email" value="<%= client.email || '' %>" required />
                                            </div>
                                            <div class="actions">
                                                <button class="secondary" type="submit">Update</button>
                                            </div>
                                        </form>
                                        <form method="post" action="/views/clients/<%= client.id %>/delete">
                                            <div class="actions">
                                                <button class="danger" type="submit">Delete</button>
                                            </div>
                                        </form>
                                    </td>
                                </tr>
                            <% }) %>
                        </tbody>
                    </table>
                <% } %>
            </section>
        </section>
    </main>
</body>
</html>

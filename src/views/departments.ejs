<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= title %></title>
    <style>
        :root {
            --bg: #f3f0ff;
            --panel: #ffffff;
            --ink: #2d1b69;
            --accent: #c2410c;
            --accent-soft: #ffedd5;
            --border: #ddd6fe;
            --muted: #5b546f;
            --danger: #991b1b;
        }
        * { box-sizing: border-box; }
        body {
            margin: 0;
            font-family: "Palatino Linotype", "Book Antiqua", serif;
            color: var(--ink);
            background:
                radial-gradient(circle at top left, rgba(194, 65, 12, 0.16), transparent 28%),
                linear-gradient(180deg, #faf7ff, var(--bg));
        }
        main {
            max-width: 1150px;
            margin: 0 auto;
            padding: 42px 20px 60px;
        }
        header {
            display: flex;
            justify-content: space-between;
            align-items: end;
            gap: 16px;
            flex-wrap: wrap;
        }
        h1, h2 { margin: 0; }
        a { color: var(--accent); text-decoration: none; font-weight: 700; }
        .layout {
            display: grid;
            grid-template-columns: 320px 1fr;
            gap: 20px;
            margin-top: 24px;
        }
        .panel {
            background: var(--panel);
            border: 1px solid var(--border);
            border-radius: 22px;
            padding: 22px;
            box-shadow: 0 18px 50px rgba(45, 27, 105, 0.08);
        }
        .notice, .error {
            margin-top: 18px;
            padding: 14px 16px;
            border-radius: 14px;
        }
        .notice {
            background: #dcfce7;
            color: #166534;
        }
        .error {
            background: #fef2f2;
            color: #991b1b;
        }
        .muted { color: var(--muted); }
        .form-grid {
            display: grid;
            gap: 12px;
            margin-top: 16px;
        }
        label {
            display: grid;
            gap: 6px;
            font-weight: 700;
        }
        input {
            width: 100%;
            padding: 11px 12px;
            border: 1px solid var(--border);
            border-radius: 12px;
            font: inherit;
        }
        button {
            border: 0;
            border-radius: 12px;
            padding: 11px 14px;
            font: inherit;
            font-weight: 700;
            cursor: pointer;
        }
        .primary {
            background: var(--accent);
            color: white;
        }
        .secondary {
            background: var(--accent-soft);
            color: var(--accent);
        }
        .danger {
            background: #fee2e2;
            color: var(--danger);
        }
        .content-stack {
            display: grid;
            gap: 20px;
        }
        .department-card + .department-card {
            margin-top: 16px;
        }
        .department-card {
            border: 1px solid var(--border);
            border-radius: 16px;
            padding: 18px;
        }
        .row-form {
            display: grid;
            gap: 10px;
            margin-top: 12px;
        }
        .row-grid {
            display: grid;
            grid-template-columns: repeat(2, minmax(140px, 1fr));
            gap: 10px;
        }
        .actions {
            display: flex;
            flex-wrap: wrap;
            gap: 8px;
        }
        .stat {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 12px 0;
            border-bottom: 1px solid var(--border);
        }
        .stat:last-child { border-bottom: 0; }
        .value {
            color: var(--accent);
            font-size: 1.2rem;
            font-weight: 700;
        }
        @media (max-width: 900px) {
            .layout { grid-template-columns: 1fr; }
            .row-grid { grid-template-columns: 1fr; }
        }
    </style>
</head>
<body>
    <main>
        <header>
            <div>
                <a href="/">Back to dashboard</a>
                <h1>Departments</h1>
            </div>
            <p>Department data and percentage summary rendered with EJS.</p>
        </header>

        <% if (message) { %>
            <div class="<%= messageType === 'error' ? 'error' : 'notice' %>"><%= message %></div>
        <% } %>

        <% if (error) { %>
            <div class="error">Unable to load departments: <%= error %></div>
        <% } %>

        <section class="layout">
            <aside class="content-stack">
                <article class="panel">
                    <h2>Create department</h2>
                    <p class="muted">Add departments from the views page.</p>
                    <form class="form-grid" method="post" action="/views/departments">
                        <label>
                            Name
                            <input type="text" name="name" placeholder="Department name" required />
                        </label>
                        <label>
                            Location
                            <input type="text" name="location" placeholder="Office location" required />
                        </label>
                        <button class="primary" type="submit">Create department</button>
                    </form>
                </article>

                <aside class="panel">
                    <h2>Client share</h2>
                    <% if (!percentages) { %>
                        <p class="muted">Percentages are unavailable.</p>
                    <% } else { %>
                        <% Object.entries(percentages).forEach(([name, value]) => { %>
                            <div class="stat">
                                <span><%= name %></span>
                                <span class="value"><%= Number(value).toFixed(1) %>%</span>
                            </div>
                        <% }) %>
                    <% } %>
                </aside>
            </aside>

            <article class="panel">
                <h2>Department list</h2>
                <% if (!departments.length) { %>
                    <p class="muted">No departments are available right now.</p>
                <% } else { %>
                    <% departments.forEach((department) => { %>
                        <section class="department-card">
                            <strong><%= department.name %></strong><br />
                            <span class="muted">ID <%= department.id %> • <%= department.location %></span>

                            <form class="row-form" method="post" action="/views/departments/<%= department.id %>/update">
                                <div class="row-grid">
                                    <input type="text" name="name" value="<%= department.name %>" required />
                                    <input type="text" name="location" value="<%= department.location %>" required />
                                </div>
                                <div class="actions">
                                    <button class="secondary" type="submit">Update</button>
                                </div>
                            </form>

                            <form method="post" action="/views/departments/<%= department.id %>/delete">
                                <div class="actions">
                                    <button class="danger" type="submit">Delete</button>
                                </div>
                            </form>
                        </section>
                    <% }) %>
                <% } %>
            </article>
        </section>
    </main>
</body>
</html>
